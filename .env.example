# Copy this to .env.local for local dev (never commit the real values).
# In production, set these as Environment Variables in the Vercel project instead.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Local dev: http://localhost:3000
# Production: your Vercel URL, e.g. https://content-library-iota.vercel.app
NEXTAUTH_URL=
